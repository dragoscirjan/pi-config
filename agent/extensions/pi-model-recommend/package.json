{
  "name": "pi-model-recommend",
  "version": "1.0.0",
  "description": "Smart model recommendation and failover for Pi",
  "main": "index.ts",
  "scripts": {
    "lint": "npx eslint \"./**/*.{ts,js,mjs,cjs}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "npx prettier --check \"./**/*.{ts,js,json,md,yml,yaml}\"",
    "format:fix": "npx prettier --write \"./**/*.{ts,js,json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pi": {
    "extensions": ["./index.ts"]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.7"
  },
  "devDependencies": {
    "@templ-project/vitest": "^0.3.2"
  }
}
