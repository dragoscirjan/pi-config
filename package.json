{
  "name": "pi-config",
  "private": true,
  "workspaces": [
    "agent/extensions/*"
  ],
  "scripts": {
    "lint": "npx eslint \"agent/extensions/**/*.{ts,js,mjs,cjs}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "npx prettier --check \"agent/extensions/**/*.{ts,js,json,md,yml,yaml}\"",
    "format:fix": "npx prettier --write \"agent/extensions/**/*.{ts,js,json,md,yml,yaml}\"",
    "dupcheck": "npx jscpd --config .jscpd.json",
    "fallow:check": "npx fallow --summary",
    "fallow:audit": "npx fallow audit --base refactor",
    "fallow:dead-code": "npx fallow dead-code",
    "fallow:dupes": "npx fallow dupes",
    "fallow:health": "npx fallow health",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "quality": "npm run lint && npm run format && npm run dupcheck && npm run fallow:check && npm run test && npm run typecheck",
    "quality:fix": "npm run lint:fix && npm run format:fix"
  },
  "prettier": "@templ-project/prettier",
  "devDependencies": {
    "@jscpd/html-reporter": "^4.2.5",
    "@templ-project/eslint": "^1.3.0",
    "@templ-project/prettier": "^1.1.0",
    "@templ-project/vitest": "^0.3.2",
    "fallow": "^3.3.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.12"
  }
}
