{
  "settings": {
    "toolPrefix": "server",
    "idleTimeout": 10
  },
  "mcpServers": {
    "browser_playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--executable-path",
        "${BROWSER_PATH}"
      ]
    },
    "codeindex_gitnexus": {
      "command": "gitnexus",
      "args": ["mcp"]
    },
    "cvs_github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}",
        "X-MCP-Toolsets": "repos,issues",
        "X-MCP-Readonly": "true"
      }
    },
    "docs_context7": {
      "url": "https://mcp.context7.com/mcp"
    },
    "docs_github_grep": {
      "url": "https://mcp.grep.app"
    },
    "memory_json": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${PROJECT_PATH}/.memory.jsonl"
      }
    },
    "sequential_thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "webcrawl_searchable": {
      "command": "npx",
      "args": ["-y", "@dragoscirjan/mcp-searchable@latest"]
    }
  }
}
