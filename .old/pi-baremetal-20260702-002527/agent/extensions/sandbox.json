{
  "enabled": true,
  "filesystem": {
    "denyRead": [
      "~/.ssh", "~/.aws", "~/.gnupg", 
      "**/.env", "**/.env.local", "**/.env.development", "**/.env.production", 
      "**/.env.test", "**/.env.staging", "**/.npmrc", "**/.pypirc", 
      "**/.docker/config.json", "**/settings.xml", "**/gradle.properties"
    ],
    "allowWrite": [".", "/tmp"],
    "denyWrite": [
      "**/.env", "**/.env.ai", "**/.env.local", "**/.env.development", 
      "**/.env.production", "**/.env.test", "**/.env.staging", "**/.npmrc", 
      "**/.pypirc", "**/.docker/config.json", "**/settings.xml", "**/gradle.properties",
      "*.pem", "*.key"
    ]
  }
}
